<?xml version="1.0" encoding="UTF-8"?>
<!--
  Local Gravity — canonical Info.plist for permissions & capabilities.
  In SPM this file is reference-only. Copy these keys into the app target's
  Info.plist when migrating to Xcode (P1-T2 Step 3 of the plan).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSCameraUsageDescription</key>
    <string>用于查看实时画面</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>用于跟 AI 对话</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>用于把你说的话转成文字</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>用于记录散步轨迹</string>
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>用于在手机锁屏时继续记录散步轨迹</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>用于连接影石相机的 WiFi 热点</string>
    <key>NSBonjourServices</key>
    <array>
        <!-- LOOKUP: confirm exact Bonjour service identifiers from Insta360 SDK -->
        <string>_insta360._tcp</string>
        <string>_http._tcp</string>
    </array>
    <key>UIBackgroundModes</key>
    <array>
        <string>location</string>
        <string>audio</string>
    </array>
</dict>
</plist>
